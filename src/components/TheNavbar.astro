---
const links = [
  { href: "#services", label: "/services" },
  { href: "#products", label: "/products" },
  { href: "#about", label: "/about" },
]
---

<nav
  class="sticky top-0 z-10 flex items-center justify-between border-b border-line bg-nav px-6 py-5 backdrop-blur-md md:px-14"
>
  <a href="/" class="flex items-center gap-3">
    <img
      src="/logo.webp"
      alt="SAJAM"
      class="h-[34px] w-auto"
    />
    <span class="text-[19px] font-bold tracking-[0.04em]">SAJAM</span>
  </a>

  <div class="flex items-center gap-4 md:gap-[30px]">
    <div
      class="hidden items-center gap-[30px] font-mono text-sm text-muted md:flex"
    >
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-inherit no-underline transition-colors hover:text-accent"
          >
            {l.label}
          </a>
        ))
      }
    </div>

    <button
      id="theme-toggle"
      type="button"
      title="Toggle theme"
      aria-label="Toggle theme"
      class="theme-toggle"
    >
      <svg
        class="sun-and-moon"
        aria-hidden="true"
        viewBox="0 0 24 24"
        fill="none"
      >
        <mask
          class="moon"
          id="theme-toggle-moon"
        >
          <rect
            x="0"
            y="0"
            width="100%"
            height="100%"
            fill="white"
          />
          <circle
            cx="24"
            cy="10"
            r="6"
            fill="black"
          />
        </mask>
        <circle
          class="sun"
          cx="12"
          cy="12"
          r="6"
          mask="url(#theme-toggle-moon)"
          fill="currentColor"
        />
        <g
          class="sun-beams"
          stroke="currentColor"
        >
          <line x1="12" y1="1" x2="12" y2="3" />
          <line x1="12" y1="21" x2="12" y2="23" />
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
          <line x1="1" y1="12" x2="3" y2="12" />
          <line x1="21" y1="12" x2="23" y2="12" />
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </g>
      </svg>
    </button>

    <a
      href="#contact"
      class="btn-cta rounded-lg px-[22px] py-2.5 font-semibold no-underline"
    >
      Contact
    </a>
  </div>
</nav>

<script>
  type Theme = "light" | "dark"

  const btn = document.getElementById("theme-toggle")

  function currentTheme(): Theme {
    return document.documentElement.dataset.theme === "dark" ? "dark" : "light"
  }

  function label(theme: Theme) {
    return theme === "dark" ? "Switch to light theme" : "Switch to dark theme"
  }

  // Sync the accessible label with whatever the pre-paint script applied.
  btn?.setAttribute("aria-label", label(currentTheme()))

  btn?.addEventListener("click", () => {
    const next: Theme = currentTheme() === "dark" ? "light" : "dark"
    document.documentElement.dataset.theme = next
    btn.setAttribute("aria-label", label(next))
    try {
      localStorage.setItem("sajam-theme", next)
    } catch {}
  })
</script>
