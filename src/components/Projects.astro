---
import { Image } from "astro:assets"
import _2048club from "~/assets/imgs/2048club.webp"
import { projects } from "~/lib/projects"
---

<section id="projects" class="flex flex-col gap-8 py-20">
  <h2
    class="text-5xl font-bold uppercase"
    style="font-family: 'Syne', sans-serif;"
  >
    Featured Projects
  </h2>
  <div class="grid gap-12 md:grid-cols-2">
    {
      projects.map((p) => (
        <div
          class="bg-white border-4 border-black p-6 flex flex-col gap-4"
          style="box-shadow: 8px 8px 0 #000;"
        >
          <Image
            class="w-full border-2 border-black"
            width={480}
            height={270}
            src={p.img}
            alt={p.name}
          />
          <div class="flex-1 flex flex-col gap-2">
            <h3
              class="text-3xl font-bold"
              style="font-family: 'Syne', sans-serif;"
            >
              {p.name}
            </h3>
            <p class="flex-1 font-mono">{p.description}</p>

            <div class="flex flex-wrap gap-2 items-center"></div>
            <div class="flex gap-4 mt-4">
              {p.src && (
                <a
                  class="btn btn-primary"
                  title={`Visit ${p.name}`}
                  href={p.src}
                  target="_blank"
                  rel="alternate"
                >
                  <span>Visit</span>
                  <span class="icon-[mdi--arrow-right] text-xl" />
                </a>
              )}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
