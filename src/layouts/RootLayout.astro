---
import TheFooter from "~/components/TheFooter.astro"
import BaseHead from "./BaseHead.astro"

export interface Props {
  class?: string
  title: string
  description: string
  ogImg?: string
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...Astro.props} />
    <slot name="head" />
  </head>
  <body class:list={["min-h-svh", Astro.props.class]}>
    <slot />
    <TheFooter />
  </body>
</html>
